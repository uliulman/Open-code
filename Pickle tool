import json
import requests

def main():
    # Get user input
    user_input = input("Enter data to serialize: ")
    
    # Create data dictionary
    data = {
        "message": user_input,
        "type": "string"
    }
    
    # HTTP endpoint (replace with your actual Java server)
    url = "http://localhost:8080/api/deserialize"
    
    # Set headers
    headers = {
        "Content-Type": "application/json"
    }
    
    try:
        # Send POST request with serialized data
        response = requests.post(url, json=data, headers=headers)
        
        print(f"[DCUDebug] Status Code: {response.status_code}")
        
        # Parse response
        try:
            json_response = response.json()
        except:
            json_response = {"raw": response.text}
        
        print(f"[DCUDebug] Response: {json.dumps(json_response, indent=2)}")
        
        # Check for expected response
        if response.status_code == 200:
            if json_response.get("status") == "success":
                print("[DCUDebug] SUCCESS: Server successfully deserialized the data!")
            else:
                print("[DCUDebug] WARNING: Response received but status not 'success'")
        elif response.status_code == 400:
            print(f"[DCUDebug] ERROR: Invalid request - {json_response.get('error', 'Unknown error')}")
        elif response.status_code == 500:
            print(f"[DCUDebug] ERROR: Server error - {json_response.get('error', 'Internal server error')}")
        else:
            print(f"[DCUDebug] UNEXPECTED: Received status code {response.status_code}")
        
    except requests.exceptions.ConnectionError:
        print(f"[DCUDebug] Error: Could not connect to server at {url}")
    except Exception as e:
        print(f"[DCUDebug] Error: {e}")

if __name__ == "__main__":
    main()
